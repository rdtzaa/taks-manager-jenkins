{
  "name": "task-manager",
  "version": "1.0.0",
  "description": "Task Manager Web App - CI/CD Demo with Jenkins & SonarQube",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage --coverageReporters=lcov --coverageReporters=text",
    "test:ci": "jest --coverage --coverageReporters=lcov --coverageReporters=text --forceExit"
  },
  "keywords": ["task-manager", "express", "jenkins", "sonarqube"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/public/**"
    ],
    "coverageDirectory": "coverage"
  }
}